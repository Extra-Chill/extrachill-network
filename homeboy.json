{
  "auto_cleanup": false,
  "changelog_target": "docs/CHANGELOG.md",
  "extensions": {
    "wordpress": {}
  },
  "id": "extrachill-network",
  "remote_path": "wp-content/plugins/extrachill-network",
  "self_checks": {
    "test": [
      "php tests/FrontendPathResolverTest.php",
      "php tests/FrontendPathResolverRuntimeTest.php"
    ]
  },
  "version_targets": [
    {
      "file": "extrachill-network.php",
      "pattern": "Version:\\s*([0-9.]+)"
    },
    {
      "file": "extrachill-network.php",
      "pattern": "EXTRACHILL_NETWORK_VERSION',\\s*'([0-9.]+)'"
    }
  ]
}
