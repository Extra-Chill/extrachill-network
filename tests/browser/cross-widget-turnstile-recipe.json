{
  "schema": "wp-codebox/workspace-recipe/v1",
  "runtime": {
    "backend": "wordpress-playground",
    "name": "ec-turnstile-cross-widget-smoke",
    "wp": "6.9",
    "blueprint": {
      "steps": [
        {
          "step": "login",
          "username": "admin",
          "password": "password"
        }
      ]
    }
  },
  "inputs": {
    "mounts": [
      {
        "source": "../../",
        "target": "/wordpress/wp-content/plugins/extrachill-network",
        "mode": "readonly",
        "metadata": {
          "kind": "component",
          "slug": "extrachill-network",
          "editable": false
        }
      }
    ]
  },
  "workflow": {
    "steps": [
      {
        "command": "wordpress.wp-cli",
        "args": [
          "command=plugin activate extrachill-network"
        ]
      },
      {
        "command": "wordpress.run-php",
        "args": [
          "code-file=./seed-two-widgets.php"
        ]
      },
      {
        "command": "wordpress.browser-probe",
        "args": [
          "url=/?pagename=ec-turnstile-cross-widget-smoke",
          "wait-for=load",
          "duration=2s",
          "capture=console,errors,screenshot"
        ]
      }
    ]
  },
  "artifacts": {
    "directory": "./artifacts"
  }
}
